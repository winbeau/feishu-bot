FEISHU_APP_ID=local-feishu-app-id
FEISHU_APP_SECRET=local-feishu-app-secret
FEISHU_VERIFICATION_TOKEN=local-feishu-verification-token
DIFY_API_KEY=your-dify-api-key
DIFY_BASE_URL=http://your-dify-server/v1
DIFY_RESPONSE_MODE=streaming
DIFY_FILE_UPLOAD_TIMEOUT_SECONDS=30
DIFY_FILE_UPLOAD_MAX_BYTES=15728640
DIFY_IMAGE_DEFAULT_QUERY=请分析这张图片
PUBLIC_FILE_BASE_URL=https://your-bot-domain
PUBLIC_FILE_DIR=/tmp/feishu-bot-public-files
REDIS_URL=redis://localhost:6380/0
